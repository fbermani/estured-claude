# EstuRed — Variables de entorno
# Copiar a .env.local y completar. NUNCA commitear .env.local.
# Convención oficial: docs/15_ENVIRONMENT_AND_SETUP.md

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=EstuRed

# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo server-side. Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# Selector de sesión simulada — SOLO desarrollo local. NUNCA en Vercel.
# Crear los usuarios con: node --env-file=.env.local scripts/seed-demo-users.mjs
DEMO_LOGIN_ENABLED=
DEMO_USERS_PASSWORD=

# Protege /api/cron/expire-stale-records (docs/07 §31, migración 0013).
# Generar un valor random (ej. `openssl rand -hex 32`) y usar el mismo
# valor acá y en el `cron.schedule` de la migración 0013.
CRON_SECRET=
